<svg xmlns="http://www.w3.org/2000/svg" width="600" height="600" viewBox="0 0 600 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#16213e"/>
      <stop offset="100%" style="stop-color:#0f3460"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FFB703;stop-opacity:0.15"/>
      <stop offset="100%" style="stop-color:#FFB703;stop-opacity:0.05"/>
    </linearGradient>
  </defs>
  <rect width="600" height="600" fill="url(#bg)"/>
  <rect x="40" y="40" width="520" height="520" rx="12" fill="none" stroke="#FFB703" stroke-opacity="0.2" stroke-width="1"/>
  <rect x="60" y="60" width="480" height="480" rx="8" fill="url(#glow)"/>
  <text x="300" y="220" font-family="Arial,sans-serif" font-size="80" fill="#FFB703" text-anchor="middle" opacity="0.9">🛣</text>
  <text x="300" y="300" font-family="Arial,sans-serif" font-size="24" font-weight="bold" fill="#ffffff" text-anchor="middle">Autopista</text>
  <text x="300" y="340" font-family="Arial,sans-serif" font-size="16" fill="#666680" text-anchor="middle">Rosario · 45km señalizados</text>
  <text x="300" y="540" font-family="Arial,sans-serif" font-size="12" fill="#666680" text-anchor="middle" opacity="0.5">Tecnolight</text>
</svg>